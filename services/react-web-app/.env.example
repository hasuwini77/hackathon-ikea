# Couchbase Edge Server Configuration
# URL of the local Couchbase Lite Edge Server
VITE_COUCHBASE_URL=http://127.0.0.1:59840

# Database name for IKEA products
VITE_COUCHBASE_DB=ikea_products

# Network request timeout in milliseconds
VITE_REQUEST_TIMEOUT=5000

# Sync status polling interval in milliseconds
VITE_SYNC_POLL_INTERVAL=10000

# Retry configuration
VITE_RETRY_ATTEMPTS=3
VITE_RETRY_DELAY=1000

# Feature Flags
# Enable offline mode functionality
VITE_OFFLINE_MODE=true

# Enable camera scanner feature
VITE_CAMERA_SCANNER=true

# API Proxy Configuration (for development)
# FastAPI backend URL
VITE_FASTAPI_URL=http://127.0.0.1:8000

# Sentry Error Tracking
# Sentry DSN (Data Source Name) for error tracking
# Get this from your Sentry project settings
# Leave as placeholder to disable Sentry
VITE_SENTRY_DSN=https://example@sentry.io/123

# Environment name for Sentry (development, staging, production)
VITE_ENV=development

# Application version for Sentry release tracking
VITE_APP_VERSION=1.0.0

# Sentry authentication token for source map uploads (build-time only)
# Get this from Sentry: Settings > Auth Tokens
# Only needed for production builds
SENTRY_AUTH_TOKEN=your-auth-token-here

# Sentry organization slug (for source map uploads)
# Get this from your Sentry organization settings
SENTRY_ORG=your-org-slug

# Sentry project slug (for source map uploads)
# Get this from your Sentry project settings
SENTRY_PROJECT=your-project-slug
